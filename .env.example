# --- deploy.sh settings (host-specific, not consumed by docker compose) ---

# SSH target for deploy.sh. Required.
# VPS=root@myvps

# Optional: remote install path. Defaults to /opt/llm-observability.
# TARGET=/opt/llm-observability

# --- docker compose settings ---

# Grafana admin password — used on first boot to seed the `admin` user.
# After Grafana is running, change it through the UI and this value is ignored.
GRAFANA_PASSWORD=changeme-grafana

# Host loopback port that Grafana binds to. Fronted by `tailscale serve`
# for HTTPS on the tailnet — not publicly exposed.
GRAFANA_HOST_PORT=3033

# Optional: root URL Grafana should generate absolute links with.
# Set this if you're fronting Grafana behind `tailscale serve` or a reverse
# proxy so redirects / embeds use the public URL.
# Example: https://myhost.example-tailnet.ts.net:3033
# GRAFANA_ROOT_URL=

# TSDB retention for Prometheus. Default 30d.
PROMETHEUS_RETENTION=30d

# Optional: adopt existing named Docker volumes instead of creating new
# ones. Useful when migrating from a previous Prometheus/Grafana stack
# (e.g. an old compose project) so historical data is preserved. Leave
# commented for a fresh install — compose will create defaults.
# PROMETHEUS_VOLUME=mystack_prometheus-data
# GRAFANA_VOLUME=mystack_grafana-data
